---
type SocialLink = {
  name: string;
  href: string;
  label: string;
};

const socialLinks: SocialLink[] = [
  { name: 'facebook', href: 'https://www.facebook.com/', label: 'f' },
  { name: 'instagram', href: 'https://www.instagram.com/', label: '◎' },
  { name: 'linkedin', href: 'https://www.linkedin.com/', label: 'in' },
  { name: 'x', href: 'https://www.twitter.com/', label: '𝕏' },
  { name: 'tiktok', href: 'https://www.tiktok.com/pt-BR/', label: '♪' },
  { name: 'threads', href: 'https://www.threads.net/', label: '@' },
  { name: 'youtube', href: 'https://www.youtube.com/', label: '▶' },
  { name: 'kwai', href: 'https://www.kwai.com/', label: '↗' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="Astro" />
    <title>Coming soon | Propaga</title>
    <meta name="description" content="Propaga Health" />
    <meta property="og:url" content="https://propaga.com.br/" />
    <meta property="og:title" content="Coming soon | Propaga" />
    <meta property="og:site_name" content="Propaga" />
    <meta property="og:type" content="website" />
    <meta name="twitter:title" content="Coming soon | Propaga" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href="https://propaga.com.br/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="page" aria-label="Propaga Health">
      <section id="propaga" class="hero">
        <div class="hero__background" aria-hidden="true"></div>
        <div class="hero__overlay" aria-hidden="true"></div>

        <div class="hero__content">
          <nav class="social social--main" aria-label="Redes sociais principais">
            {
              socialLinks.map((item) => (
                <a class="social__link" href={item.href} target="_blank" rel="noopener noreferrer" aria-label={item.name}>
                  <span>{item.label}</span>
                </a>
              ))
            }
          </nav>

          <article class="address" aria-label="Endereço Propaga Health">
            <h1>Propaga Health</h1>
            <p>Avenida Juscelino Kubitschek, 1.700 - Edifício Plaza JK</p>
            <p>5º Andar &amp; 11º Andar - Vila Olímpia - 04552-080 - São Paulo</p>
          </article>

          <article class="contact" aria-label="Contato Propaga Health">
            <a class="contact__email" href="mailto:contato@propaga.com.br">contato@propaga.com.br</a>
            <a class="contact__phone" href="tel:+5519984324111">+55 (19) 98432-4111</a>
          </article>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --font-primary: 'Roboto', Arial, sans-serif;
    --white: #fff;
    --dark: #0f0a14;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    font-family: var(--font-primary);
    color: var(--white);
    background: var(--dark);
  }

  a {
    color: inherit;
  }

  .page {
    min-height: 100vh;
  }

  .hero {
    position: relative;
    min-height: 882px;
    overflow: hidden;
    background: var(--dark);
  }

  .hero__background {
    position: absolute;
    inset: 0;
    background-color: #0f0a14;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)),
      url('https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=1920,fit=crop/mp8vzozxMEUbKZv9/propaga-health-YrDWWgZ50lS8p48e.png'),
      radial-gradient(circle at 25% 12%, rgba(216, 244, 255, 0.5) 0 8%, transparent 28%),
      radial-gradient(circle at 55% 36%, rgba(124, 189, 176, 0.55) 0 12%, transparent 34%),
      linear-gradient(145deg, #274c5a 0%, #6a9c96 44%, #15283b 100%);
    background-position: top center;
    background-size: cover;
    background-repeat: no-repeat;
    transform: translateZ(0);
    background-attachment: fixed;
  }

  .hero__background::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 10, 20, 0.08), rgba(15, 10, 20, 0.18));
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: min(1224px, calc(100% - 32px));
    min-height: 882px;
    margin: 0 auto;
    padding: 70px 0 58px;
    display: grid;
    grid-template-columns: 32% 18% 50%;
    grid-template-rows: 1fr auto 16px auto 16px auto;
  }

  .social {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .social--main {
    grid-column: 1 / 2;
    grid-row: 6 / 7;
    width: min(489px, 100%);
    justify-content: space-around;
  }

  .social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: #fff;
    text-decoration: none;
    font-size: 17px;
    font-weight: 600;
    line-height: 1;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .social__link:hover {
    opacity: 0.72;
    transform: scale(1.05);
  }

  .social__link[aria-label='linkedin'] span {
    font-size: 14px;
    letter-spacing: -0.05em;
  }

  .address {
    grid-column: 3 / 4;
    grid-row: 2 / 7;
    align-self: end;
    text-align: right;
  }

  .address h1 {
    margin: 0 0 17px;
    font-size: 18px;
    line-height: 1.3;
    font-weight: 600;
  }

  .address p {
    margin: 0;
    font-size: 18px;
    line-height: 1.3;
    font-weight: 400;
  }

  .address p + p {
    margin-top: 16px;
  }

  .contact {
    grid-column: 1 / 2;
    grid-row: 2 / 6;
    align-self: end;
    display: grid;
    gap: 16px;
    justify-items: start;
  }

  .contact a {
    display: inline-block;
    text-decoration: none;
    font-size: 18px;
    line-height: 1.3;
    font-weight: 400;
  }

  .contact__email {
    text-decoration: underline !important;
    text-underline-offset: 2px;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 586px;
    }

    .hero__background {
      position: absolute;
      background-position: top center;
    }

    .hero__content {
      width: min(328px, calc(100% - 32px));
      min-height: 586px;
      padding: 40px 0 19px;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .social--main {
      order: 1;
      width: 100%;
      margin-bottom: 16px;
      gap: 0;
      justify-content: space-around;
    }

    .address {
      order: 2;
      text-align: left;
      align-self: stretch;
    }

    .address h1 {
      margin-bottom: 16px;
      font-size: 18px;
    }

    .address p {
      min-height: 131px;
      font-size: 18px;
    }

    .address p + p {
      margin-top: 16px;
    }

    .contact {
      order: 3;
      align-self: stretch;
      margin-top: 16px;
      gap: 16px;
    }

    .contact a {
      font-size: 18px;
    }

    .contact__phone {
      min-height: 44px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }
</style>
